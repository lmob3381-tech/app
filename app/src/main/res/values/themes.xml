<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RouterManager" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_green</item>
        <item name="colorPrimaryDark">@color/brand_green_dark</item>
        <item name="colorAccent">@color/brand_green</item>
        <item name="android:statusBarColor">@color/brand_green_dark</item>
        <item name="android:windowBackground">@color/bg_light</item>
    </style>

    <style name="QuickBtn" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">13sp</item>
        <item name="strokeColor">@color/brand_green</item>
        <item name="android:textColor">@color/brand_green_dark</item>
        <item name="cornerRadius">18dp</item>
    </style>
</resources>
